{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist/plugin",
    "rootDir": "src",
    "typeRoots": ["node_modules/@figma"]
  },
  "include": ["src/plugin/**/*.ts", "src/shared/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
