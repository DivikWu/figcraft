{
  "name": "figcraft-workspace",
  "version": "0.1.0",
  "description": "AI-powered Figma plugin for design quality, UI creation, Token sync, Lint, Audit, Auto-fix via MCP.",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "figma",
    "mcp",
    "design-system",
    "design-tokens",
    "dtcg",
    "lint",
    "wcag",
    "accessibility"
  ],
  "license": "MIT",
  "scripts": {
    "dev:relay": "tsx packages/relay/src/index.ts",
    "dev:mcp": "tsx packages/figcraft-design/src/index.ts",
    "schema": "node --import tsx scripts/compile-schema.ts && node scripts/sync-auto-approve.mjs",
    "content": "node --import tsx scripts/compile-content.ts",
    "check:schema-generated": "npm run schema && npm run docs:contracts && test -z \"$(git status --porcelain -- packages/core-mcp/src/tools/_generated.ts packages/core-mcp/src/tools/_registry.ts packages/core-mcp/src/tools/_contracts.ts docs/generated/api-contracts.md)\"",
    "build": "npm run schema && npm run content && npm run build:server && npm run build:plugin && npm run build -w figcraft-design",
    "build:plugin": "node packages/adapter-figma/build.plugin.mjs",
    "build:server": "tsup --config tsup.config.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.plugin.json",
    "docs:contracts": "node scripts/generate-api-contract-doc.mjs",
    "test": "vitest --run --config vitest.workspace.ts",
    "test:watch": "vitest --config vitest.workspace.ts",
    "test:coverage": "vitest --run --config vitest.workspace.ts --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "release:verify": "npm run check:schema-generated && npm run lint && npm run typecheck && npm run test && npm run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,mts,js,mjs,json}": "biome check --write --no-errors-on-unmatched"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@figma/plugin-typings": "^1",
    "@types/ws": "^8",
    "@vitest/coverage-v8": "^4.1.2",
    "esbuild": "^0.27.4",
    "fast-check": "^4.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsup": "^8",
    "tsx": "^4",
    "typescript": "^5.9",
    "vitest": "^4.1.0",
    "yaml": "^2.8.2"
  }
}
