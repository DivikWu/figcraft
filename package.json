{
  "name": "figcraft",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered Figma plugin for design system compliance — Token sync, Lint, Auto-fix, Element generation via MCP",
  "type": "module",
  "scripts": {
    "dev:relay": "tsx src/relay/index.ts",
    "dev:mcp": "tsx src/mcp-server/index.ts",
    "build": "tsup",
    "build:plugin": "tsup --config tsup.plugin.config.ts",
    "build:server": "tsup --config tsup.server.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1",
    "ws": "^8",
    "zod": "^3.23"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1",
    "@types/ws": "^8",
    "tsup": "^8",
    "tsx": "^4",
    "typescript": "^5.9"
  }
}
