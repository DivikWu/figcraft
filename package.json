{
  "name": "figcraft-design",
  "version": "0.1.0",
  "description": "AI-powered Figma plugin for design system compliance — Token sync, Lint, Auto-fix, Element generation via MCP",
  "bin": {
    "figcraft-design": "./dist/mcp-server/index.js"
  },
  "files": [
    "dist/mcp-server/",
    "dist/relay/",
    "README.md"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "figma",
    "mcp",
    "design-system",
    "design-tokens",
    "dtcg",
    "lint",
    "wcag",
    "accessibility"
  ],
  "license": "MIT",
  "scripts": {
    "dev:relay": "tsx src/relay/index.ts",
    "dev:mcp": "tsx src/mcp-server/index.ts",
    "build": "tsup",
    "build:plugin": "node build.plugin.mjs",
    "build:server": "tsup --config tsup.server.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1",
    "ws": "^8",
    "zod": "^3.23"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1",
    "@types/ws": "^8",
    "esbuild": "^0.27.4",
    "tsup": "^8",
    "tsx": "^4",
    "typescript": "^5.9",
    "vitest": "^4.1.0"
  }
}
